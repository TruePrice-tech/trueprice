  ],
  "commonJobs": {
    "removal_only": { "label": "Tear-off existing gutters", "total": [200, 600], "perLinearFoot": [1.50, 4.00] },
    "single_story_5inch": { "label": "Single-story home, 5-inch aluminum (~150 LF)", "total": [1400, 2700] },
    "single_story_6inch": { "label": "Single-story home, 6-inch aluminum (~150 LF)", "total": [1700, 3300] },
    "two_story_5inch": { "label": "Two-story home, 5-inch (~200 LF)", "total": [2000, 4500] },
    "two_story_6inch": { "label": "Two-story home, 6-inch (~200 LF)", "total": [2400, 5500] },
    "copper_full_house": { "label": "Full copper (~200 LF)", "total": [5500, 14000] },
    "guards_only": { "label": "Gutter guards on existing gutters (~200 LF)", "total": [600, 5000], "notes": "LeafFilter and similar premium brands $15-$25/ft installed; big-box guards $3-$8/ft." },
    "downspout_extensions": { "label": "Downspout extensions or buried drainage", "total": [200, 1500] },
    "fascia_repair": { "label": "Fascia/soffit repair revealed under old gutters", "total": [400, 2500] }
  },
  "supportingComponents": [
    { "item": "Drip edge install (if missing)", "perLinearFoot": [3, 7], "necessary": "always", "notes": "Code-required if gutters added to a roof without it." },
    { "item": "Hidden hangers every 24-32 inches", "perEach": [2, 5], "necessary": "always", "notes": "Spike-and-ferrule installs are obsolete — refuse them." },
    { "item": "Splash blocks or downspout extensions", "perEach": [10, 50], "necessary": "always" },
    { "item": "Kickout flashing where roof meets wall", "perEach": [25, 90], "necessary": "always" }
  ],
  "redFlagPatterns": [
    {
      "key": "spike_and_ferrule",
      "severity": "high",
      "regex": "\\b(spike|ferrule|spike[- ]?and[- ]?ferrule|nailed)\\b",
      "explanation": "Spike-and-ferrule hangers are obsolete since the 1990s. Spikes back out, gutters sag. Demand hidden hangers every 24-32 inches."
    },
    {
      "key": "no_kickout_flashing",
      "severity": "critical",
      "regex": "\\b(roof line|wall|sidewall|abutment|where roof meets wall|stair[- ]?step)\\b",
      "secondaryRegex": "\\b(kickout|kick[- ]?out|diverter|flashing)\\b",
      "matchInverseSecondary": true,
      "explanation": "Kickout flashing is required by IRC 2009+ where the gutter meets a wall. Missing kickouts are the #1 cause of post-install wall rot."
    },
    {
      "key": "no_drip_edge",
      "severity": "high",
      "regex": "\\b(no drip edge|missing drip edge)\\b",
      "explanation": "Drip edge is code-required (IRC R905.2.8.5) and must be installed before gutters. Skipping it leads to fascia rot."
    },
    {
      "key": "5_inch_in_heavy_rain",
      "severity": "medium",
      "regex": "\\b(5[- ]?inch|five inch|5\")\\b",
      "secondaryRegex": "\\b(steep|two[- ]?story|2[- ]?story|heavy rain|tropical|monsoon)\\b",
      "explanation": "5-inch on a steep two-story or heavy-rain home. 6-inch handles 40% more flow. Worth the upgrade."
    },
    {
      "key": "leaffilter_high_pressure",
      "severity": "medium",
      "regex": "\\b(leaffilter|leaf filter)\\b",
      "secondaryRegex": "\\b(today only|today's price|expires|sign now|special|discount)\\b",
      "explanation": "LeafFilter is known for high-pressure today-only sales tactics with prices often 2-3x competitive micro-mesh. Get a competitive local quote before signing."
    },
    {
      "key": "no_downspout_drainage",
      "severity": "medium",
      "regex": "\\b(downspout|leader)\\b",
      "secondaryRegex": "\\b(splash block|extension|drainage|away from foundation|buried)\\b",
      "matchInverseSecondary": true,
      "explanation": "Quote installs downspouts but no extensions or drainage. Water dumped at the foundation causes basement leaks."
    },
    {
      "key": "fascia_rot_ignored",
      "severity": "high",
      "regex": "\\b(fascia|rotted|wood damage|soffit damage)\\b",
      "secondaryRegex": "\\b(replace|repair|fix|carpentry|extra)\\b",
      "matchInverseSecondary": true,
      "explanation": "Fascia/soffit damage mentioned but no repair scope. Hanging new gutters on rotted fascia means they'll fall off within a year."
    },
    {
      "key": "no_warranty",
      "severity": "low",
      "regex": "\\b(warranty|guarantee)\\b",
      "matchInverse": true,
      "explanation": "No workmanship warranty. Reputable gutter companies offer 2-10 year warranties."
    },
    {
      "key": "deposit_above_25",
      "severity": "high",
      "regex": "\\b(deposit|down payment|upfront)\\b",
      "explanation": "Deposit above 25% on a small gutter job is unusual. Most reputable gutter companies bill on completion."
    }
  ],
  "scopeCheckItems": [
    { "key": "material",      "label": "Material and gauge specified",                 "weight": 12 },
    { "key": "size",          "label": "5-inch vs 6-inch noted",                       "weight": 11 },
    { "key": "hangerType",    "label": "Hidden hangers (not spike-and-ferrule)",       "weight": 13 },
    { "key": "kickout",       "label": "Kickout flashing where roof meets wall",       "weight": 13 },
    { "key": "dripEdge",      "label": "Drip edge present or installed",               "weight": 10 },
    { "key": "downspoutDrain","label": "Downspouts extended away from foundation",     "weight": 10 },
    { "key": "fasciaCheck",   "label": "Underlying fascia/soffit assessed",            "weight": 10 },
    { "key": "warranty",      "label": "Workmanship warranty",                         "weight": 8 },
    { "key": "guards",        "label": "Gutter guard brand/type if included",          "weight": 7 },
    { "key": "cleanup",       "label": "Cleanup and old gutter disposal included",    "weight": 6 }
  ],
  "iraCredit": { "section": "N/A", "status": "NOT_APPLICABLE", "notes": "Gutters do not qualify for federal energy credits." },
