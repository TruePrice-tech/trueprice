  "stateLicensing": {
    "notes": "Gutter installers are typically licensed under the state general contractor license.",
    "requiresGCLicense": ["AL", "AZ", "CA", "CT", "FL", "GA", "HI", "LA", "MA", "MN", "NV", "NJ", "NC", "OR", "RI", "SC", "TN", "VA", "WA"]
  },
  "questionsToAskContractor": [
    "What material and gauge are you quoting?",
    "5-inch or 6-inch — and why for my home?",
    "Hidden hangers every 24-32 inches (not spike-and-ferrule)?",
    "Where will you install kickout flashing?",
    "Is drip edge present? Will you add it if missing?",
    "How will downspouts be extended away from the foundation?",
    "Any fascia or soffit repair needed before install?",
    "What is the workmanship warranty?",
    "If guards are included: which brand and product line?"
  ]
