{
  "functions": {
    "api/parse-quote.js": {
      "maxDuration": 30
    },
    "api/geocode-suggest.js": {
      "maxDuration": 10
    },
    "api/property-signals.js": {
      "maxDuration": 15
    },
    "api/community-quote.js": {
      "maxDuration": 10
    },
    "api/contractor-signup.js": {
      "maxDuration": 10
    }
  },
  "headers": [
    {
      "source": "/css/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/js/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/(.*).html",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=3600, stale-while-revalidate=86400" }
      ]
    }
  ],
  "trailingSlash": false,
  "cleanUrls": false
}
